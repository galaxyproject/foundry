---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import RunPipelines from '../../components/RunPipelines.astro';
import { listAllCasts, loadAssembly } from '../../lib/casts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const casts = listAllCasts();

const runnablePipelines = (await getCollection('content'))
  .filter(n => n.data.type === 'pipeline' && n.data.status !== 'archived')
  .filter(p => loadAssembly(p.id.split('/').pop()!)).length;

// Resolve mold backlinks by name → entry slug.
const molds = (await getCollection('content')).filter(e => e.data.type === 'mold');
const moldByName = new Map<string, string>();
for (const m of molds) {
  const name = (m.data as any).name;
  if (name) moldByName.set(name, m.id);
}

const TARGET_ORDER: Array<'claude' | 'web' | 'generic'> = ['claude', 'web', 'generic'];
const TARGET_LABEL: Record<string, string> = {
  claude: 'Shared Agent Skills',
  web: 'Web skills',
  generic: 'Generic skills',
};

const byTarget = new Map<string, typeof casts>();
for (const c of casts) {
  const list = byTarget.get(c.target) ?? [];
  list.push(c);
  byTarget.set(c.target, list);
}

const sharedSkillCount = (byTarget.get('claude') ?? []).length;
---
<Base title="Usage">
  <section class="page-hero bg-grain" aria-labelledby="usage-heading">
    <span class="eyebrow mb-3">Usage</span>
    <div class="page-hero-grid">
      <div>
        <h1 id="usage-heading" class="page-title text-balance">Install and run Foundry skills with Claude Code or Codex.</h1>
        <p class="page-lede text-pretty">
          The Foundry casts each Mold into a self-contained skill, and assembles each Pipeline into a
          runnable harness. Both are committed under <code class="font-mono">casts/</code> and surfaced
          as one shared Agent Skills bundle with thin Claude Code and Codex plugin metadata. Install
          once in your runtime; <a href="#run-pipelines">run a pipeline</a> end-to-end or invoke any
          cast skill directly.
        </p>
      </div>
      <dl class="page-stats" aria-label="Cast inventory stats">
        <div>
          <dt>Pipelines</dt>
          <dd>{runnablePipelines}</dd>
        </div>
        <div>
          <dt>Shared skills</dt>
          <dd>{sharedSkillCount}</dd>
        </div>
        <div>
          <dt>Casts</dt>
          <dd>{casts.length}</dd>
        </div>
      </dl>
    </div>
  </section>

  <section id="install" class="mb-10" aria-labelledby="install-heading" style="scroll-margin-top: 5rem;">
    <div class="section-rule">
      <h2 id="install-heading">Install</h2>
      <span class="section-tail">/ one bundle, two runtimes</span>
    </div>

    <p class="mb-3">
      <strong>Claude Code.</strong> Add the marketplace and install the plugin:
    </p>
    <pre class="p-3 rounded-lg bg-(--color-surface-raised) text-sm font-mono overflow-x-auto"><code>/plugin marketplace add galaxyproject/foundry
/plugin install foundry-skills@galaxy-workflow-foundry</code></pre>

    <p class="mt-4 mb-2">
      Skills are namespaced under the plugin. Invoke a cast skill in a session like:
    </p>
    <pre class="p-3 rounded-lg bg-(--color-surface-raised) text-sm font-mono overflow-x-auto"><code>/foundry-skills:summarize-nextflow</code></pre>

    <p class="mt-6 mb-3">
      <strong>Codex.</strong> Add the same repository marketplace and install the same plugin:
    </p>
    <pre class="p-3 rounded-lg bg-(--color-surface-raised) text-sm font-mono overflow-x-auto"><code>codex plugin marketplace add galaxyproject/foundry
codex plugin add foundry-skills@galaxy-workflow-foundry</code></pre>

    <p class="mt-4 mb-2">
      In Codex CLI or the IDE, run <code class="font-mono">/skills</code> or type <code class="font-mono">$</code>
      to select a skill explicitly:
    </p>
    <pre class="p-3 rounded-lg bg-(--color-surface-raised) text-sm font-mono overflow-x-auto"><code>$summarize-nextflow</code></pre>
    <p class="mt-3 text-sm text-(--color-text-secondary)">
      Codex may also select a skill implicitly when your task matches its description.
    </p>

    <p class="mt-4 mb-2 text-sm text-(--color-text-secondary)">
      Or skip plugin installation and copy a single skill into the runtime's user skill directory:
    </p>
    <pre class="p-3 rounded-lg bg-(--color-surface-raised) text-sm font-mono overflow-x-auto"><code>git clone https://github.com/galaxyproject/foundry
cp -r foundry/casts/claude/skills/&lt;name&gt; ~/.claude/skills/&lt;name&gt;  # Claude Code
cp -r foundry/casts/claude/skills/&lt;name&gt; ~/.agents/skills/&lt;name&gt;  # Codex</code></pre>

    <p class="mt-4 text-sm text-(--color-text-secondary)">
      Update Claude Code with <code class="font-mono">/plugin update foundry-skills@galaxy-workflow-foundry</code>.
      Refresh the Codex marketplace with <code class="font-mono">codex plugin marketplace upgrade galaxy-workflow-foundry</code>.
      Restart the runtime if updated skills do not appear.
    </p>
  </section>

  <section id="run-pipelines" class="mb-10" aria-labelledby="run-heading" style="scroll-margin-top: 5rem;">
    <RunPipelines variant="full" />
  </section>

  {TARGET_ORDER.map(target => {
    const list = byTarget.get(target) ?? [];
    if (list.length === 0) return null;
    return (
      <section class="mb-10" aria-labelledby={`target-${target}-heading`}>
        <div class="section-rule">
          <h2 id={`target-${target}-heading`}>{TARGET_LABEL[target]}</h2>
          <span class="section-tail">/ {list.length} cast{list.length === 1 ? '' : 's'}</span>
        </div>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 list-none p-0 m-0">
          {list.map(c => {
            const moldId = moldByName.get(c.moldSlug);
            const skillHref = target === 'claude' ? `${base}/usage/claude/${c.moldSlug}/` : null;
            return (
              <li class="p-4 rounded-lg border border-(--color-border) hover:border-(--color-galaxy-primary) transition-colors">
                <div class="flex items-baseline justify-between gap-2 mb-1">
                  {skillHref
                    ? <a href={skillHref} class="font-mono font-semibold text-(--color-link) hover:underline">{c.moldSlug}</a>
                    : <span class="font-mono font-semibold">{c.moldSlug}</span>}
                  {moldId && (
                    <a href={`${base}/${moldId.replace(/\/index$/, '')}/`} class="text-xs text-(--color-text-secondary) hover:underline">
                      Source mold →
                    </a>
                  )}
                </div>
                {c.description && <p class="text-sm text-(--color-text-secondary) m-0">{c.description}</p>}
              </li>
            );
          })}
        </ul>
      </section>
    );
  })}
</Base>
