---
import type { CollectionEntry } from 'astro:content';
import { schemaRegistry } from '../lib/schema-registry';

interface Props {
  entry: CollectionEntry<'content'>;
}

const { entry } = Astro.props;
const data = entry.data as any;
const reg = schemaRegistry[data.name];

interface Property {
  name: string;
  type: string;
  description?: string;
  required: boolean;
  default?: unknown;
  constValue?: unknown;
}

interface DefView {
  id: string;
  title: string;
  description?: string;
  properties: Property[];
  required: string[];
}

function renderType(prop: any): string {
  if (!prop) return '';
  if (prop.const !== undefined) return `const "${prop.const}"`;
  if (prop.$ref) return `→ ${String(prop.$ref).replace('#/$defs/', '')}`;
  if (prop.anyOf) {
    return prop.anyOf.map(renderType).filter(Boolean).join(' | ');
  }
  if (prop.oneOf) {
    return prop.oneOf.map(renderType).filter(Boolean).join(' | ');
  }
  if (prop.type === 'array') {
    return `${renderType(prop.items) || 'any'}[]`;
  }
  if (Array.isArray(prop.type)) return prop.type.join(' | ');
  return prop.type ?? 'any';
}

function viewFromNode(id: string, node: any): DefView | null {
  if (!node || typeof node !== 'object') return null;
  const required = Array.isArray(node.required) ? node.required : [];
  const defProps = (node.properties ?? {}) as Record<string, any>;
  const props: Property[] = Object.entries(defProps).map(([propName, propNode]) => ({
    name: propName,
    type: renderType(propNode),
    description: (propNode as any)?.description,
    required: required.includes(propName),
    default: (propNode as any)?.default,
    constValue: (propNode as any)?.const,
  }));
  // Sort: required first, then alphabetical by name (but keep `that` discriminator first if present).
  props.sort((a, b) => {
    if (a.name === 'that') return -1;
    if (b.name === 'that') return 1;
    if (a.required !== b.required) return a.required ? -1 : 1;
    return a.name.localeCompare(b.name);
  });
  return { id, title: node.title ?? id, description: node.description, properties: props, required };
}

function buildDefViews(schema: Record<string, unknown> | undefined): DefView[] {
  if (!schema) return [];
  // Support both draft 2019+ ($defs) and draft-07 (definitions).
  const defs = {
    ...((schema['$defs'] as Record<string, any>) ?? {}),
    ...((schema['definitions'] as Record<string, any>) ?? {}),
  };
  const views: DefView[] = [];
  for (const [defName, defNode] of Object.entries(defs)) {
    const v = viewFromNode(defName, defNode);
    if (v) views.push(v);
  }
  views.sort((a, b) => a.id.localeCompare(b.id));
  return views;
}

// Object-root schemas (e.g. cast-provenance, summary-cwl) carry their main
// shape in top-level `properties`; surface that as a stable `#root` section
// ahead of the definitions. $ref-only or array roots contribute nothing.
function buildRootView(schema: Record<string, unknown> | undefined): DefView | null {
  const s = schema as any;
  if (!s?.properties || Object.keys(s.properties).length === 0) return null;
  return viewFromNode('root', s);
}

const defViews = reg ? buildDefViews(reg.schema) : [];
const rootView = reg ? buildRootView(reg.schema) : null;
const allViews = rootView ? [rootView, ...defViews] : defViews;
const root = reg?.schema as any;
const rootDescription = root?.description as string | undefined;
const rootTitle = root?.title as string | undefined;
---
<div class="mb-6 flex flex-wrap gap-2 items-center">
  <span class="text-xs px-2 py-1 rounded bg-(--color-galaxy-primary) text-white font-mono">schema</span>
  <span class="text-xs px-2 py-1 rounded border border-(--color-border) font-mono">{data.name}</span>
  {data.package && (
    <span class="text-xs px-2 py-1 rounded border border-(--color-border) font-mono">
      {data.package}{reg && ` @ ${reg.version}`}
    </span>
  )}
  {data.upstream && (
    <a href={data.upstream} class="text-xs text-(--color-link) hover:underline">upstream ↗</a>
  )}
</div>

{!reg && (
  <div class="mb-6 p-3 rounded-lg border border-(--color-border) bg-(--color-surface-raised) text-sm">
    No schema registered for <code>{data.name}</code>. Add an entry to <code>site/src/lib/schema-registry.ts</code>.
  </div>
)}

{reg && (
  <section class="mb-8 p-4 rounded-lg border border-(--color-border) bg-(--color-surface-raised)">
    {rootTitle && <h2 class="not-prose text-lg font-semibold mb-2">{rootTitle}</h2>}
    {rootDescription && <p class="not-prose text-sm text-(--color-text-secondary) m-0">{rootDescription}</p>}
    <div class="mt-3 text-xs text-(--color-text-secondary)">
      {allViews.length} sections. Anchor links per section (e.g. <code>#root</code>) are stable.
    </div>
  </section>
)}

{reg && allViews.length > 0 && (
  <nav class="mb-8 p-3 rounded-lg border border-(--color-border) text-xs">
    <details>
      <summary class="cursor-pointer font-semibold text-sm">All sections ({allViews.length})</summary>
      <ul class="not-prose mt-2 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-1 list-none p-0">
        {allViews.map(d => (
          <li><a href={`#${d.id}`} class="text-(--color-link) hover:underline font-mono text-xs">{d.id}</a></li>
        ))}
      </ul>
    </details>
  </nav>
)}

<div class="space-y-6">
  {allViews.map(d => (
    <section id={d.id} class="not-prose p-4 rounded-lg border border-(--color-border) scroll-mt-20">
      <header class="flex flex-wrap items-baseline gap-2 mb-2">
        <h3 class="text-base font-semibold m-0">
          <a href={`#${d.id}`} class="text-(--color-text-primary) hover:underline">{d.title}</a>
        </h3>
        <code class="text-xs text-(--color-text-secondary)">{d.id}</code>
      </header>
      {d.description && (
        <p class="text-sm text-(--color-text-secondary) mb-3 whitespace-pre-line m-0">{d.description}</p>
      )}
      {d.properties.length > 0 && (
        <table class="w-full text-xs border-collapse">
          <thead>
            <tr class="border-b border-(--color-border)">
              <th class="text-left py-1 pr-2 font-semibold">field</th>
              <th class="text-left py-1 pr-2 font-semibold">type</th>
              <th class="text-left py-1 pr-2 font-semibold">req</th>
              <th class="text-left py-1 font-semibold">description</th>
            </tr>
          </thead>
          <tbody>
            {d.properties.map(p => (
              <tr class="border-b border-(--color-border) align-top">
                <td class="py-1 pr-2 font-mono">
                  {p.name}
                  {p.constValue !== undefined && (
                    <span class="text-(--color-text-secondary)"> = "{String(p.constValue)}"</span>
                  )}
                </td>
                <td class="py-1 pr-2 font-mono text-(--color-text-secondary)">{p.type}</td>
                <td class="py-1 pr-2">{p.required ? '✓' : ''}</td>
                <td class="py-1">
                  {p.description}
                  {p.default !== undefined && p.default !== null && p.constValue === undefined && (
                    <span class="block text-(--color-text-secondary) mt-0.5">default: <code>{JSON.stringify(p.default)}</code></span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </section>
  ))}
</div>
